   "source": [
    "%matplotlib inline\n",
    "%config InlineBackend.figure_format = 'retina'\n",
    "%load_ext autoreload\n",
    "%autoreload 2\n",
    "import matplotlib.pyplot as plt\n",
    "from IPython.core.display import HTML\n",
    "HTML('<style>.container { width:95% !important; }</style><style>.output_png {display: table-cell;text-align: center;vertical-align: middle;}</style>')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.metrics.pairwise import pairwise_kernels\n",
    "import numpy as np\n",
    "def plot_analysis(embeddings, force_ylim=True):\n",
    "    K = pairwise_kernels(embeddings, metric='cosine')\n",
    "    plt.imshow(K, cmap='gray')\n",
    "    plt.show()\n",
    "    \n",
    "    size = K.shape[0]\n",
    "    plt.plot(K[0], label='0/4')\n",
    "    plt.plot(K[size//4], label='1/4')\n",
    "    plt.plot(K[size//2], label='1/2')\n",
    "    plt.plot(K[size//4*3], label='3/4')\n",
    "    plt.plot(K[-1], label='4/4')\n",
    "    if force_ylim: \n",
    "        plt.ylim(-0.05,1.05)\n",
    "        plt.yticks(np.arange(0,1.1,0.1))\n",
    "    plt.grid(lw=.5)\n",
    "    plt.legend()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2",
   "metadata": {},
   "outputs": [],
   "source": [
    "import networkx as nx\n",
    "import random\n",
    "def make_graph_reductions(graph, n_iter=None):\n",
    "    if n_iter is None: n_iter  = nx.number_of_edges(graph)//3 * 2\n",
    "    out_graphs = []\n",
    "    g = graph.copy()\n",
    "    out_graphs.append(g.copy())\n",
    "    for i in range(n_iter):\n",
    "        edges = [e for e in g.edges()]\n",
    "        e = random.choice(edges)\n",
    "        g.remove_edge(*e)\n",
    "        out_graphs.append(g.copy())\n",
    "    return out_graphs"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3",
   "metadata": {},
   "source": [
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4",
   "metadata": {},
   "outputs": [],
   "source": [
    "from coco_grape.utils.artificial_graph_constructor import ArtificialGraphConstructor\n",
    "artificial_graph_constructor = ArtificialGraphConstructor(graph_type='regular', instance_size=30, alphabet_size=5)\n",
    "graph = artificial_graph_constructor.sample(1)\n",
    "out_graphs = make_graph_reductions(graph)\n",
    "from coco_grape.visualizer.display import draw_graphs\n",
    "draw_graphs(out_graphs, n_graphs_per_line=9)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5",
   "metadata": {},
   "outputs": [],
   "source": [
    "from NSPPK.nsppk import NSPPK \n",
    "embeddings = NSPPK(radius=2, distance=3, nbits=10, parallel=True).fit_transform(out_graphs)\n",
    "plot_analysis(embeddings)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6",
   "metadata": {},
   "outputs": [],
   "source": [
    "from abstractgraph.vectorize import AbstractGraphTransformer\n",
    "from abstractgraph.operators import *"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = graphlet(number_of_nodes=5, radius=2)\n",
    "embeddings = AbstractGraphTransformer(decomposition_function=df, nbits=10, n_jobs=-1).fit_transform(out_graphs)\n",
    "plot_analysis(embeddings)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = add(cycle(), compose(neighborhood(radius=(0,2)), tree()))\n",
    "embeddings = AbstractGraphTransformer(decomposition_function=df, nbits=10, n_jobs=-1).fit_transform(out_graphs)\n",
    "plot_analysis(embeddings)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = neighborhood(radius=(0,2))\n",
    "embeddings = AbstractGraphTransformer(decomposition_function=df, nbits=10, n_jobs=-1).fit_transform(out_graphs)\n",
    "plot_analysis(embeddings)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "10",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = add(neighborhood(radius=(0,2)), cycle(), graphlet(number_of_nodes=5, radius=2))\n",
    "embeddings = AbstractGraphTransformer(decomposition_function=df, nbits=10, n_jobs=-1).fit_transform(out_graphs)\n",
    "plot_analysis(embeddings)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "11",
   "metadata": {},
   "source": [
    "---"
   ]
  }
