   "source": [
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "34",
   "metadata": {},
   "outputs": [],
   "source": [
    "step1 = compose(connected_component(), complement(), betweenness_centrality(number_of_nodes=5))\n",
    "\n",
    "@curry\n",
    "def number_of_image_graph_nodes_greater_then(abstract_graph, threshold=1):\n",
    "    return number_of_image_graph_nodes(abstract_graph) > threshold\n",
    "\n",
    "workflow = compose(\n",
    "    if_then_else(\n",
    "        predicate=number_of_image_graph_nodes_greater_then(threshold=2),\n",
    "        then_function=merge(),\n",
    "        else_function=identity()\n",
    "    ),\n",
    "    step1,\n",
    ")\n",
    "draw(graph, workflow)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "35",
   "metadata": {},
   "outputs": [],
   "source": [
    "df1 = neighborhood()\n",
    "df = for_loop(function=df1, n_iterations=3)\n",
    "df = compose(deduplicate(), df)\n",
    "draw(graph, df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e816548a",
   "metadata": {},
   "outputs": [],
   "source": [
    "from abstractgraph.operators import *\n",
    "core_df = split(n_parts=5)\n",
    "connector_df = compose(connected_component(), edge_complement(), merge(use_edges=True), core_df)\n",
    "df = compose(intersection_edges(), add(connector_df, core_df))\n",
    "\n",
    "draw(graph, df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "36",
   "metadata": {},
   "outputs": [],
   "source": [
    "@curry\n",
    "def number_of_image_graph_nodes_less_then(abstract_graph, threshold=1):\n",
    "    return number_of_image_graph_nodes(abstract_graph) < threshold\n",
    "\n",
    "@curry\n",
    "def number_of_subgraph_nodes_greater_then(abstract_graph, threshold=1):\n",
    "    return max_number_of_subgraph_nodes(abstract_graph) >= threshold\n",
    "\n",
    "\n",
    "core_df = forward_compose(\n",
    "    while_loop(\n",
    "        function=split(),\n",
    "        predicate=number_of_subgraph_nodes_greater_then(threshold=5),\n",
    "        max_iterations=10\n",
    "    ),\n",
    "    connected_component()\n",
    ")\n",
    "\n",
    "connector_df = compose(connected_component(), edge_complement(), merge(use_edges=True), core_df)\n",
    "df = compose(intersection_edges(), add(connector_df, core_df))\n",
    "\n",
    "draw(graph, df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "37",
   "metadata": {},
   "outputs": [],
   "source": [
    "#decomposition used for feasibility filters\n",
    "df1 = neighborhood(radius=1)\n",
    "df2 = compose(cycle(), unlabel())\n",
    "df3 = compose(filter_by_number_of_connected_components(number_of_components=1), combination(distance=0), compose(cycle(), unlabel()))\n",
    "df = add(df1,df2,df3)\n",
    "draw(graph, df)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "38",
   "metadata": {},
   "source": [
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "39",
   "metadata": {},
   "outputs": [],
   "source": [
    "cycle_df = compose(filter_by_number_of_nodes(number_of_nodes=(5,6)), cycle())\n",
    "cycle_with_N_df = compose(filter_by_node_label(must_have_one_of=['N']), cycle())\n",
    "pairs_df = compose_product(binary_combination(distance=(1,4)), cycle_df, cycle_with_N_df)\n",
    "df = compose(intersection_edges(), pairs_df)\n",
    "draw(graph, df)"
   ]
  },
  {
   "cell_type": "code",
