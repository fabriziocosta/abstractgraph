  {
   "cell_type": "markdown",
   "id": "42",
   "metadata": {},
   "source": [
    "# Vectorization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "43",
   "metadata": {},
   "outputs": [],
   "source": [
    "from abstractgraph.graphs import AbstractGraph\n",
    "from abstractgraph.vectorize import vectorize\n",
    "from abstractgraph.operators import *\n",
    "decomposition_function = add(node(), edge())\n",
    "from coco_grape.utils.artificial_graph_constructor import RandomGraphConstructor\n",
    "graph = RandomGraphConstructor(integers_range=12, instance_size=40, alphabet_size=4, attribute_size=3).sample()\n",
    "\n",
    "ag = AbstractGraph(graph=graph).create_default_image_node()\n",
    "ag = decomposition_function(ag)\n",
    "X = vectorize(ag, nbits=10)\n",
    "X.shape"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "44",
   "metadata": {},
   "outputs": [],
   "source": [
    "from abstractgraph.vectorize import AbstractGraphTransformer\n",
    "from abstractgraph.operators import *\n",
