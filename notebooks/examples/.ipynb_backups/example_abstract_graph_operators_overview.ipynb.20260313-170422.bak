   "id": "30",
   "metadata": {},
   "outputs": [],
   "source": [
    "#NSPPK\n",
    "def make_nsppk(radius=1, distance=3, thickness=1):\n",
    "    if thickness == 0:\n",
    "        df = add(union_of_shortest_paths(length=distance), compose(combination(number_of_elements=2,distance=(0,distance)), neighborhood(radius=(0,radius))))\n",
    "    elif thickness == 1:\n",
    "        df = compose(combination(number_of_elements=2,distance=(0,distance)), neighborhood(radius=(0,radius)))\n",
    "    else:\n",
    "        raise Exception(f'thickness {thickness} is not allowed')\n",
    "    return df\n",
    "\n",
    "df = make_nsppk(radius=1, distance=3, thickness=1)\n",
    "draw(graph, df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "31",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = compose(\n",
    "    filter_by_number_of_connected_components(number_of_components=(2,3)), \n",
    "    combination(number_of_elements=(2,3),distance=(1,2)), neighborhood(radius=(0,2)))\n",
    "draw(graph, df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "32",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Note: compose_product(binary_combination(distance=(0,1)), cycle(), tree()) computes cycle(Q) and tree(Q) on the same input and feeds both to binary_combination.\n",
    "df = compose_product(binary_combination(distance=0), cycle(), tree())\n",
    "draw(graph, df)"
   ]
